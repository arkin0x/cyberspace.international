        </a>

        <a href="/docs/coordinates.html" class="bg-slate-800/50 border border-slate-700 hover:border-cyan-500 rounded-lg p-5 transition-colors group">
          <h3 class="text-lg font-semibold text-cyan-400 group-hover:text-cyan-300 mb-2">← Coordinate System</h3>
