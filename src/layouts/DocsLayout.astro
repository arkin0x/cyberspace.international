---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Cyberspace Protocol Documentation — technical guides and specifications for thermodynamic digital space' } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <header class="border-b border-slate-800 bg-slate-900/50 backdrop-blur">
    <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="text-xl font-bold bg-gradient-to-r from-cyan-400 to-purple-400 bg-clip-text text-transparent">
        cyberspace.international
      </a>
      <div class="flex gap-6 text-sm">
        <a href="/about" class="text-slate-400 hover:text-cyan-400 transition-colors">About</a>
        <a href="/docs" class="text-slate-400 hover:text-cyan-400 transition-colors">Docs</a>
        <a href="/blog" class="text-slate-400 hover:text-cyan-400 transition-colors">Blog</a>
      </div>
    </nav>
  </header>

  <main class="max-w-6xl mx-auto px-6 py-12">
    {description && <p class="text-xl text-slate-400 mb-8">{description}</p>}
    <slot />
  </main>

  <footer class="border-t border-slate-800 mt-20 py-8">
    <div class="max-w-6xl mx-auto px-6 text-center text-slate-500 text-sm">
      <p>Cyberspace Protocol .  Imposing thermodynamic locality on digital systems</p>
      <p class="mt-2">Built with Cantor pairing trees & proof-of-work</p>
    </div>
  </footer>
</BaseLayout>

<style>
  :global(body) {
    font-family: system-ui, -apple-system, sans-serif;
  }
</style>
